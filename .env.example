# Copy to `.env` in this folder (repo root, next to netlify.toml). Optional: `.env.local`
# overrides values here. Restart `netlify dev` after changes.
# Set the same keys in Netlify → Site → Environment variables for production.

# --- Stripe (required for /pay/ and checkout) ---
# Developers → API keys → Secret key (must start with sk_test_ or sk_live_).
# Do NOT put the Publishable key (pk_...) here.
STRIPE_SECRET_KEY=sk_test_REPLACE_ME

# Or split names (first non-empty wins in code):
# STRIPE_TEST_SECRET_KEY=sk_test_...
# STRIPE_LIVE_SECRET_KEY=sk_live_...
# STRIPE_SECRET_KEY_TEST=sk_test_...

# Webhook signing secret (must start with whsec_...). NOT pk_ or sk_.
# Stripe Dashboard webhook endpoint, or `stripe listen` CLI output for local dev.
STRIPE_WEBHOOK_SECRET=whsec_REPLACE_ME

# Optional: fixed-price Checkout using a Price ID (if set, amount can be omitted in some flows)
# STRIPE_PRICE_ID=price_xxx

# --- OpenAI (Concierge Daemon chat + lead engine) ---
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4.1-mini
# (Use full id; "4.1-mini" alone is invalid — code may normalize it, but prefer gpt-4.1-mini.)

# --- Supabase (optional: referrals + consultations logging from webhook) ---
# SUPABASE_URL=
# SUPABASE_SERVICE_ROLE_KEY=

# --- Lead engine (/lead-engine/) — copy these to Netlify with Functions scope ---
# LEAD_ENGINE_ENABLED=true
# LEAD_ENGINE_SECRET=long-random-string
# LEAD_ENGINE_OPERATORS=ops:your-password-here   (required for login; not LEAD_ENGINE_ADMIN_EMAIL)
# If ENABLED is missing/mis-read but OPERATORS + SECRET are set, the app still enables (deploy latest code).
# LEAD_ENGINE_ALLOW_OPENAI=true
# LEAD_ENGINE_PUBLIC_SITE_URL=https://www.example.com
# Required before lead-engine can send outreach (Resend + CAN-SPAM footer):
# RESEND_API_KEY=re_...
# Optional: defaults to FORM_FROM_EMAIL or Resend onboarding sender
# LEAD_ENGINE_OUTREACH_FROM_EMAIL=JL Solutions <info@yourdomain.com>
# Postal mailing line for email footer (required for send; shown in small print in the message)
# LEAD_ENGINE_PHYSICAL_ADDRESS=Laurel, MD 20707

# --- Site URL (Netlify sets URL automatically in production) ---
# URL=http://localhost:8888
