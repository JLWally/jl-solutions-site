# Copy to `.env` in this folder (repo root, next to netlify.toml). Optional: `.env.local`
# overrides values here. Restart `netlify dev` after changes.
# Set the same keys in Netlify → Site → Environment variables for production.
# Go-live checklist (Stripe live + webhooks + Resend + Payment Links): docs/LIVE-REVENUE.md
# Quick check: npm run verify:live-revenue  (uses this file; never commit real secrets)
#
# Netlify Blobs (smart demos, referrals blob path, form audit): production injects context automatically.
#
# Linking this folder to the RIGHT site (not jl-solutions-academy):
# - `netlify link` → "Use current git remote" only works if that GitHub repo has ONE Netlify site.
#   If origin is github.com/JLWally/jl-solutions-site and Netlify only knows the academy, you get the wrong site.
# - Fix: `netlify unlink` then either:
#     A) `netlify sites:list` → copy the **Site ID** for your main marketing site (jlsolutions.io), then
#        `netlify link --id PASTE_SITE_ID_HERE`
#     B) `netlify link` → choose **Enter a site ID** (or search by name) and pick the main site, not academy.
# In Netlify UI: Site → Site configuration → Site details → Site ID (UUID).
#
# Optional local fallback when Blobs context still missing (never commit real tokens):
# NETLIFY_SITE_ID=   # same UUID as main site
# NETLIFY_AUTH_TOKEN=   # User settings → Applications → Personal access tokens

# --- Stripe (required for Checkout API + onboard wizard payment step) ---
# Developers → API keys → Secret key (must start with sk_test_ or sk_live_).
# Do NOT put the Publishable key (pk_...) here.
STRIPE_SECRET_KEY=sk_test_REPLACE_ME

# Or split names (first non-empty wins in code):
# STRIPE_TEST_SECRET_KEY=sk_test_...
# STRIPE_LIVE_SECRET_KEY=sk_live_...
# STRIPE_SECRET_KEY_TEST=sk_test_...

# Webhook signing secret (must start with whsec_...). NOT pk_ or sk_.
# Stripe Dashboard webhook endpoint, or `stripe listen` CLI output for local dev.
STRIPE_WEBHOOK_SECRET=whsec_REPLACE_ME

# Optional: fixed-price Checkout using a Price ID (if set, amount can be omitted in some flows)
# STRIPE_PRICE_ID=price_xxx

# Optional: strategy session USD amounts if you use custom Checkout line items
# PAY_STRATEGY_60_USD=350
# PAY_STRATEGY_AUDIT_USD=750
# PAY_STRATEGY_TECH_USD=950

# --- OpenAI (Wattson site chat + lead engine) ---
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4.1-mini
# (Use full id; "4.1-mini" alone is invalid — code may normalize it, but prefer gpt-4.1-mini.)

# --- Post-purchase onboarding (/onboarding form → send-form-email package-kickoff) ---
# Optional: comma-separated emails for a short internal summary (full intake still goes to info@).
# ONBOARDING_OPS_EMAIL=you@example.com
# Netlify sets URL for links inside ops email; for local dev add URL=http://localhost:8888

# --- Supabase (optional: referrals + consultations logging from webhook) ---
# SUPABASE_URL=
# SUPABASE_SERVICE_ROLE_KEY=

# --- Lead engine (/lead-engine/) — copy these to Netlify with Functions scope ---
# LEAD_ENGINE_ENABLED=true
# LEAD_ENGINE_SECRET=long-random-string
# LEAD_ENGINE_OPERATORS=ops:your-password-here   (required for login; not LEAD_ENGINE_ADMIN_EMAIL)
# If ENABLED is missing/mis-read but OPERATORS + SECRET are set, the app still enables (deploy latest code).
# LEAD_ENGINE_ALLOW_OPENAI=true
# LEAD_ENGINE_PUBLIC_SITE_URL=https://www.example.com
#
# Before one-click demo outreach send (/internal/outreach) goes live, set all of:
# RESEND_API_KEY=re_...
# LEAD_ENGINE_PHYSICAL_ADDRESS=Laurel, MD 20707   (CAN-SPAM postal line in footer)
# LEAD_ENGINE_PUBLIC_SITE_URL=https://www.yoursite.com   (unsubscribe + links)
# LEAD_ENGINE_OUTREACH_FROM_EMAIL=JL Solutions <info@yourdomain.com>   (verified in Resend)
# FORM_FROM_EMAIL=JL Solutions <info@yourdomain.com>   (site forms + shared From fallback)
#
# Optional: outreach From only; else code uses FORM_FROM_EMAIL then Resend default
# LEAD_ENGINE_OUTREACH_FROM_EMAIL=JL Solutions <info@yourdomain.com>

# --- Site URL (Netlify sets URL automatically in production) ---
# URL=http://localhost:8888
